        "replicaId": {
          "type": "string"
        },
        "origination": {
          "type": [ "string", "null" ],
          "enum": [ "DigitalSurrogate", "Digitised", "BornDigital", null ]
        },
        "totalSize": {
          "type": "integer"
        }
      },
      "required": [ "replicaId", "files", "totalSize" ]
    },
    "updateScope": {
      "type": "string",
      "enum": [ "RecordOnly", "RecordAndReplica" ],
      "description": "Defines whether the update applies only to the record or to both record and replica data."
    }
  },
  "required": [ "record", "updateScope" ],
  "if": {
    "properties": {
      "record": {
        "properties": {
          "replicaId": {
            "type": "string",
            "minLength": 5
          }
        },
        "required": [ "replicaId" ]
      }
    }
  },
  "then": {
    "required": [ "replica" ]
  }
}
